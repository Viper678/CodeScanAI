# =====================================================================
# CodeScan frontend environment variables (Next.js web service).
# Copy to ``codescan-frontend/.env`` and fill in real values. Never commit
# ``.env``. Docker Compose auto-loads ``.env`` from the same directory as
# the compose file, so this lives next to ``docker-compose.yml`` rather
# than at the monorepo root.
# =====================================================================

# ---- Web (Next.js) ----
# Runtime env var read by ``next.config.mjs``'s ``rewrites()`` — Next.js
# proxies ``/api/v1/*`` to ``${INTERNAL_API_URL}/*`` server-side so the
# browser only talks to the web origin. Read at REQUEST time (not bake
# time) per docs/GCP_MIGRATION.md §D4, so one image deploys to UAT /
# prod / future staging — only the env value differs per environment.
#
# Default (in ``docker-compose.yml``): ``http://host.docker.internal:8000/api/v1``
# — reaches a backend stack running on the host (``codescan-backend/``
# compose stack). Override to ``http://api:8000/api/v1`` when both stacks
# share a docker network under the same ``-p`` project name (e2e flow).
INTERNAL_API_URL=http://host.docker.internal:8000/api/v1
