# =====================================================================
# CodeScan environment variables
# Copy to .env and fill in real values. Never commit .env.
# =====================================================================

# ---- General ----
ENV=development                       # development | production
LOG_LEVEL=info                        # debug | info | warning | error

# ---- Auth / JWT ----
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=replace-me-with-64-bytes-of-random
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_DAYS=14
PASSWORD_MIN_LENGTH=12

# ---- Database ----
POSTGRES_USER=codescan
POSTGRES_PASSWORD=codescan-dev-only-change-me
POSTGRES_DB=codescan
DATABASE_URL=postgresql+asyncpg://codescan:codescan-dev-only-change-me@postgres:5432/codescan
DATABASE_SYNC_URL=postgresql+psycopg://codescan:codescan-dev-only-change-me@postgres:5432/codescan  # for alembic

# ---- Redis ----
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ---- Storage ----
DATA_DIR=/data
MAX_UPLOAD_SIZE_MB=100
MAX_LOOSE_FILES=50
MAX_LOOSE_FILE_SIZE_MB=50
MAX_UNCOMPRESSED_TOTAL_MB=500
MAX_FILES_IN_ARCHIVE=20000
RETENTION_DAYS=30                     # TODO: confirm policy

# ---- Scan limits ----
MAX_FILES_PER_SCAN=500
MAX_SCAN_FILE_SIZE_MB=1

# ---- LLM / Gemma ----
GOOGLE_AI_API_KEY=                    # required; get from Google AI Studio
GEMMA_MODEL=gemma-4-31b-it
LLM_PARALLELISM=4                     # concurrent in-flight Gemma calls per worker
LLM_MAX_TOKENS_INPUT=120000           # cap to leave headroom in 256K context
LLM_TEMPERATURE=0.0
LLM_MAX_OUTPUT_TOKENS=4096
PROMPT_VERSION=v1

# ---- Rate limits ----
RATE_LIMIT_LOGIN=5/minute
RATE_LIMIT_REGISTER=5/minute
RATE_LIMIT_UPLOAD=10/hour
RATE_LIMIT_SCAN=30/hour

# ---- API ----
API_WORKERS=2
ALLOWED_ORIGINS=http://localhost:3000
TRUSTED_HOSTS=localhost,127.0.0.1
COOKIE_SECURE=false                   # set true in production
COOKIE_DOMAIN=                        # leave empty in dev; set to your domain in prod
CSRF_HEADER_NAME=X-Requested-With
CSRF_HEADER_VALUE=codescan

# ---- Web (Next.js) ----
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_APP_NAME=CodeScan

# ---- Observability (optional) ----
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=codescan-api
