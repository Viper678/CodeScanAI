# =====================================================================
# CodeScan environment variables
# Copy to .env and fill in real values. Never commit .env.
# =====================================================================

# ---- General ----
ENV=development                       # development | production
LOG_LEVEL=info                        # debug | info | warning | error

# ---- Auth / JWT ----
# generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_DAYS=14
COOKIE_SECURE=true                    # set to false only for local HTTP development
COOKIE_SAMESITE=lax

# ---- Database ----
POSTGRES_USER=codescan
POSTGRES_PASSWORD=codescan-dev-only-change-me
POSTGRES_DB=codescan
DATABASE_URL=postgresql+asyncpg://codescan:codescan-dev-only-change-me@postgres:5432/codescan
DATABASE_SYNC_URL=postgresql+psycopg://codescan:codescan-dev-only-change-me@postgres:5432/codescan  # for alembic

# ---- Redis ----
# Post-M3 the rate limiter, Celery broker, and Celery result backend all share
# db 0 — the worker scopes broker / result keys via ``global_keyprefix``
# (``celery-broker:`` / ``celery-result:``) so they can't collide with
# rate-limit keys (``rl:``). The three URLs are still separate env vars so
# operators can point them at different hosts for HA later.
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ---- Storage ----
# Backend selector. ``local`` keeps every artifact under ``DATA_DIR`` on
# the shared docker volume (dev / CI default). ``gcs`` routes the same
# read/write/delete operations through the ``google-cloud-storage`` SDK
# against ``STORAGE_BUCKET`` — credentials are picked up from the
# environment (Workload Identity inside GKE, ``GOOGLE_APPLICATION_CREDENTIALS``
# JSON otherwise). See docs/GCP_MIGRATION.md §D2 and docs/DEPLOYMENT.md.
STORAGE_BACKEND=local
# STORAGE_BUCKET=                       # required when STORAGE_BACKEND=gcs; otherwise unused
DATA_DIR=/data
MAX_UPLOAD_SIZE_MB=100
MAX_LOOSE_FILES=50
MAX_LOOSE_FILE_SIZE_MB=50
MAX_UNCOMPRESSED_TOTAL_MB=500
MAX_FILES_IN_ARCHIVE=20000
# Retention sweep (T5.2): disabled by default. Set to a positive integer
# (days) to enable the daily Celery beat task that purges uploads — and
# their cascaded files / scans / scan_files / scan_findings + on-disk
# artifacts — older than this many days. Leave commented out / empty to
# disable; the beat task still ticks daily but no-ops.
# RETENTION_DAYS=30

# ---- Scan limits ----
MAX_FILES_PER_SCAN=500
MAX_SCAN_FILE_SIZE_MB=1

# ---- LLM / Gemma ----
LLM_BASE_URL=http://vllm.llm.svc.cluster.local:8000/v1
# LLM_API_KEY=                        # optional; only set if vLLM was started with --api-key
GEMMA_MODEL=gemma-4-31b-it
LLM_PARALLELISM=4                     # concurrent in-flight Gemma calls per worker
LLM_MAX_TOKENS_INPUT=120000           # cap to leave headroom in 256K context
LLM_TEMPERATURE=0.0
LLM_MAX_OUTPUT_TOKENS=4096
PROMPT_VERSION=v1
# Test/CI-only switch. When ``true``, the worker swaps its real Gemma
# transport for a static-fixture mock (``apps/worker/worker/llm/
# mock_transport.py``) that returns deterministic canned findings. Used
# by the Playwright e2e suite (T5.5) via ``docker-compose.e2e.yml`` —
# **never set this in production**; it bypasses Gemma entirely.
# LLM_MOCK_MODE=false

# ---- Rate limits (T5.1) ----
# Sliding-window counts; values match docs/API.md §"Rate limits".
RATE_LIMIT_LOGIN_PER_MINUTE=5
RATE_LIMIT_REGISTER_PER_MINUTE=5
RATE_LIMIT_UPLOAD_PER_HOUR=10
RATE_LIMIT_SCAN_PER_HOUR=30

# ---- API ----
API_WORKERS=2
CORS_ALLOW_ORIGINS=http://localhost:3000
TRUSTED_HOSTS=localhost,127.0.0.1
COOKIE_DOMAIN=                        # leave empty in dev; set to your domain in prod
CSRF_HEADER_NAME=X-Requested-With
CSRF_HEADER_VALUE=codescan

# ---- Web (Next.js) ----
# Runtime env var read by ``apps/web/next.config.mjs``'s ``rewrites()`` —
# Next.js proxies ``/api/v1/*`` to ``${INTERNAL_API_URL}/*`` server-side
# so the browser only talks to the web origin. Read at REQUEST time (not
# bake time) per docs/GCP_MIGRATION.md §D4, so one image deploys to UAT /
# prod / future staging — only the env value differs per environment.
# Default targets the api service on the internal compose network.
INTERNAL_API_URL=http://api:8000/api/v1

# ---- Observability (T5.4) ----
# Structured JSON logs are always on; ``LOG_LEVEL`` (above) tunes verbosity
# (debug | info | warning | error). Each api request gets a ``request_id``
# (uuid hex, mirrored back as ``X-Request-ID``) + ``user_id`` correlation;
# each worker task gets ``task_id`` / ``scan_id`` / ``upload_id`` / ``file_id``.
# Third-party error trackers (Sentry, OTel) are intentionally not wired —
# add via a focused follow-up PR when there's actual operator intent.
